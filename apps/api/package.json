{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:prod": "prisma generate && prisma migrate deploy && node dist/main.js",
    "test": "jest",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:instance-admin": "ts-node scripts/seed-instance-admin.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "exceljs": "4.4.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/jest": "^27.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.30",
    "@types/passport-jwt": "^3.0.9",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-nestjs": "^1.2.3",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^27.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^27.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "eslintConfig": {
    "extends": "../../packages/config/eslint/nestjs.js"
  },
  "prettier": "../../packages/config/.prettierrc.js",
  "main": "dist/main.js",
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
