# API Base URL (required for production, optional in dev)
# In production: MUST be set, build will fail otherwise
# In development: defaults to http://localhost:3000
# Example: VITE_API_BASE_URL=https://authentic-endurance-production-f462.up.railway.app
VITE_API_BASE_URL=http://localhost:3000

# Demo mode: enables auto demo-login and "Try Demo" button on login screen
# Set to 'true' to enable (requires API DEMO_MODE=true as well)
# VITE_DEMO_MODE=true
