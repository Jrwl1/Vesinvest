generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// VA budget/projection enums
// ============================================

// Talousarvion tila (SV: Budgetstatus / EN: Budget status)
enum TalousarvioTila {
  luonnos // SV: utkast / EN: draft
  vahvistettu
}

// Budjettirivien tyyppi (SV: Budgetradtyp / EN: Budget line type)
enum RiviTyyppi {
  kulu // SV: kostnad / EN: expense
  tulo
  investointi // SV: investering / EN: investment
}


enum Palvelutyyppi {
  vesi // SV: vatten / EN: water
  jatevesi // SV: avloppsvatten / EN: wastewater
  muu
}

enum RiviKind {
  group
  line
}


// Semantic classification for P&L subtotal rows from KVA workbook.
enum ValisummaTyyppi {
  tulo
  kulu // SV: kostnad / EN: cost
  poisto // SV: avskrivning / EN: depreciation
  rahoitus_tulo
  rahoitus_kulu // SV: finansiell kostnad / EN: financial cost
  investointi // SV: investering / EN: investment
  tulos // SV: resultat / EN: result (computed, not projection input)
}

enum TrialStatus {
  active
  expired
  locked
}

enum LegalDocType {
  terms
  dpa
}

enum DepreciationMethod {
  linear
  residual
  none
}

enum VesinvestPlanStatus {
  draft
  active
  archived
}

enum VesinvestBaselineStatus {
  draft
  incomplete
  verified
}

enum VesinvestFeeRecommendationStatus {
  blocked
  provisional
  verified
}

enum VesinvestTariffPlanStatus {
  draft
  accepted
  stale
}

enum VesinvestIdentitySource {
  manual
  veeti
  mixed
}

enum VesinvestInvestmentType {
  sanering
  nyanlaggning
  reparation
}

enum VesinvestServiceSplit {
  water
  wastewater
  mixed
}

// ============================================
// Core models (kept as-is)
// ============================================

model Organization {
  id                       String           @id @default(uuid())
  slug                     String           @unique
  name                     String
  trialStartsAt            DateTime?        @map("trial_starts_at")
  trialEndsAt              DateTime?        @map("trial_ends_at")
  trialStatus              TrialStatus?     @default(active) @map("trial_status")
  lockReason               String?          @map("lock_reason")
  created_at               DateTime         @default(now())

  users UserRole[]

  talousarviot Talousarvio[]
  olettamukset Olettamus[]
  ennusteet    Ennuste[]
  ennusteReports EnnusteReport[]
  veetiLink    VeetiOrganisaatio?
  veetiSnapshots VeetiSnapshot[]
  veetiOverrides VeetiOverride[]
  veetiYearPolicies VeetiYearPolicy[]
  depreciationRules OrganizationDepreciationRule[]
  vesinvestPlanSeries VesinvestPlanSeries[]
  vesinvestGroupOverrides VesinvestGroupOverride[]
  vesinvestPlans VesinvestPlan[]
  vesinvestTariffPlans VesinvestTariffPlan[]
  invitations   Invitation[]
  legalAcceptances LegalAcceptance[]
}

model OrganizationDepreciationRule {
  id              String             @id @default(uuid())
  orgId           String
  org             Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assetClassKey   String             @map("asset_class_key")
  assetClassName  String?            @map("asset_class_name")
  method          DepreciationMethod
  linearYears     Int?               @map("linear_years")
  residualPercent Decimal?           @map("residual_percent")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@unique([orgId, assetClassKey])
  @@index([orgId, method])
  @@map("depreciation_rule")
}

model VeetiOrganisaatio {
  id            String       @id @default(uuid())
  orgId         String       @unique
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  veetiId       Int
  nimi          String?
  ytunnus       String?
  kunta         String?
  workspaceYears Int[]       @default([]) @map("workspace_years")
  linkedAt      DateTime     @default(now())
  lastFetchedAt DateTime?    @map("last_fetched_at")
  fetchStatus   String?      @map("fetch_status")

  @@map("veeti_organisaatio")
}

model VeetiSnapshot {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  veetiId   Int
  vuosi     Int
  dataType  String       @map("data_type")
  rawData   Json         @map("raw_data")
  fetchedAt DateTime     @default(now())

  @@unique([orgId, veetiId, vuosi, dataType])
  @@index([orgId, vuosi])
  @@map("veeti_snapshot")
}

model VeetiOverride {
  id           String       @id @default(uuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  veetiId      Int
  vuosi        Int
  dataType     String       @map("data_type")
  overrideData Json         @map("override_data")
  editedBy     String?      @map("edited_by")
  reason       String?      @map("reason")
  editedAt     DateTime     @default(now()) @map("edited_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([orgId, veetiId, vuosi, dataType])
  @@index([orgId, veetiId, vuosi])
  @@map("veeti_override")
}

model VeetiYearPolicy {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  veetiId   Int
  vuosi     Int
  excluded  Boolean      @default(false)
  includedInPlanningBaseline Boolean @default(false) @map("included_in_planning_baseline")
  reason    String?
  editedBy  String?      @map("edited_by")
  editedAt  DateTime     @default(now()) @map("edited_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@unique([orgId, veetiId, vuosi])
  @@index([orgId, veetiId, excluded])
  @@index([orgId, vuosi])
  @@map("veeti_year_policy")
}

model VeetiBenchmark {
  id          String   @id @default(uuid())
  vuosi       Int
  metricKey   String   @map("metric_key")
  kokoluokka  String
  orgCount    Int      @map("org_count")
  avgValue    Decimal  @map("avg_value")
  medianValue Decimal? @map("median_value")
  p25Value    Decimal? @map("p25_value")
  p75Value    Decimal? @map("p75_value")
  minValue    Decimal? @map("min_value")
  maxValue    Decimal? @map("max_value")
  computedAt  DateTime @default(now()) @map("computed_at")

  @@unique([vuosi, metricKey, kokoluokka])
  @@index([vuosi, metricKey])
  @@map("veeti_benchmark")
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  created_at DateTime   @default(now())
  roles      UserRole[]
  createdInvitations Invitation[] @relation("InvitationCreatedBy")
  legalAcceptances   LegalAcceptance[]
  ennusteReports     EnnusteReport[] @relation("EnnusteReportCreatedBy")
}

model Role {
  id         String     @id @default(uuid())
  name       String     @unique
  created_at DateTime   @default(now())
  users      UserRole[]
}

model UserRole {
  id         String       @id @default(uuid())
  created_at DateTime     @default(now())
  user       User         @relation(fields: [user_id], references: [id])
  user_id    String
  role       Role         @relation(fields: [role_id], references: [id])
  role_id    String
  org        Organization @relation(fields: [org_id], references: [id])
  org_id     String

  @@unique([user_id, role_id, org_id])
}

model Invitation {
  id         String       @id @default(uuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email      String
  role       String
  tokenHash  String       @map("token_hash")
  expiresAt  DateTime     @map("expires_at")
  acceptedAt DateTime?    @map("accepted_at")
  createdBy  String       @map("created_by")
  creator    User         @relation("InvitationCreatedBy", fields: [createdBy], references: [id])
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@index([orgId, email])
  @@index([tokenHash])
  @@map("invitation")
}

model LegalDocument {
  id          String       @id @default(uuid())
  docType     LegalDocType @map("doc_type")
  version     String
  contentUrl  String?      @map("content_url")
  isActive    Boolean      @default(true) @map("is_active")
  publishedAt DateTime     @default(now()) @map("published_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@unique([docType, version])
  @@index([docType, isActive])
  @@map("legal_document")
}

model LegalAcceptance {
  id           String       @id @default(uuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  termsVersion String       @map("terms_version")
  dpaVersion   String       @map("dpa_version")
  acceptedAt   DateTime     @default(now()) @map("accepted_at")
  ip           String?
  userAgent    String?      @map("user_agent")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([orgId, userId, termsVersion, dpaVersion])
  @@index([orgId, termsVersion, dpaVersion])
  @@map("legal_acceptance")
}

// ============================================
// NEW: Vesipolku Budget / Projection Models
// Finnish terminology primary; SV/EN in comments
// ============================================

// Talousarvio (SV: Budget / EN: Budget)
// Named budget profile. Multiple profiles allowed per org per year (different nimi).
model Talousarvio {
  id                    String           @id @default(uuid())
  orgId                 String
  org                   Organization     @relation(fields: [orgId], references: [id])
  vuosi                 Int              @map("vuosi")
  nimi                  String           @map("nimi")
  tila                  TalousarvioTila  @default(luonnos) // SV: status / EN: status
  perusmaksuYhteensa    Decimal?         @map("perusmaksu_yhteensa") // SV: grundavgift totalt / EN: annual base-fee total (EUR)
  importBatchId         String?          @map("import_batch_id") // KVA import: same id for 3 budgets in one run
  importSourceFileName  String?          @map("import_source_file_name")
  importedAt            DateTime?        @map("imported_at")
  lahde                 String?          @map("lahde")
  veetiVuosi            Int?             @map("veeti_vuosi")
  veetiImportedAt       DateTime?        @map("veeti_imported_at")
  userEdited            Boolean          @default(false) @map("user_edited")
  inputCompleteness     Json?            @map("input_completeness") // EN: readiness metadata for required calculation inputs
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  rivit      TalousarvioRivi[]
  tuloajurit Tuloajuri[]
  valisummat TalousarvioValisumma[]
  ennusteet  Ennuste[]

  @@unique([orgId, vuosi, nimi])
  @@index([orgId, importBatchId])
  @@map("talousarvio")
}

// TalousarvioRivi (SV: Budgetrad / EN: BudgetLine)
// Individual cost/revenue/investment line within a budget.
model TalousarvioRivi {
  id            String      @id @default(uuid())
  talousarvioId String
  talousarvio   Talousarvio @relation(fields: [talousarvioId], references: [id], onDelete: Cascade)
  parentId      String?     @map("parent_id")
  parent        TalousarvioRivi? @relation("TalousarvioRiviHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      TalousarvioRivi[] @relation("TalousarvioRiviHierarchy")
  sortOrder     Int         @default(0) @map("sort_order")
  rowKind       RiviKind    @default(line) @map("row_kind")
  serviceType   Palvelutyyppi? @map("service_type")
  imported      Boolean     @default(false) @map("imported")
  tiliryhma     String      @map("tiliryhma")
  nimi          String      @map("nimi")
  tyyppi        RiviTyyppi // SV: typ / EN: type
  summa         Decimal     @map("summa")
  muistiinpanot String?     @map("muistiinpanot") // SV: anteckningar / EN: notes
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([talousarvioId])
  @@index([talousarvioId, parentId])
  @@index([talousarvioId, sortOrder])
  @@map("talousarvio_rivi")
}

// TalousarvioValisumma (SV: Budgetmellansumma / EN: BudgetSubtotal)
// Subtotal-level P&L lines extracted from KVA workbook.
// Used for 20-year projections via "computeFromSubtotals" path.
model TalousarvioValisumma {
  id            String          @id @default(uuid())
  talousarvioId String
  talousarvio   Talousarvio     @relation(fields: [talousarvioId], references: [id], onDelete: Cascade)
  palvelutyyppi Palvelutyyppi
  categoryKey   String          @map("category_key")
  tyyppi        ValisummaTyyppi
  label         String?         @map("label")
  summa         Decimal         @map("summa")
  lahde         String?         @map("lahde")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([talousarvioId, palvelutyyppi, categoryKey])
  @@index([talousarvioId])
  @@map("talousarvio_valisumma")
}


// Unit price + volume data that budgets typically lack. Compliance-critical.
model Tuloajuri {
  id            String        @id @default(uuid())
  talousarvioId String
  talousarvio   Talousarvio   @relation(fields: [talousarvioId], references: [id], onDelete: Cascade)
  palvelutyyppi Palvelutyyppi
  yksikkohinta  Decimal       @map("yksikkohinta")
  myytyMaara    Decimal       @map("myyty_maara")
  perusmaksu    Decimal?      @map("perusmaksu")
  liittymamaara Int?          @map("liittyma_maara") // SV: antal anslutningar / EN: connectionCount
  alvProsentti  Decimal?      @map("alv_prosentti")
  sourceMeta    Json?         @map("source_meta") // EN: provenance metadata (imported/manual override/source cells)
  muistiinpanot String?       @map("muistiinpanot") // SV: anteckningar / EN: notes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([talousarvioId])
  @@map("tuloajuri")
}

// Olettamus (SV: Antagande / EN: Assumption)
// Named key-value assumptions for projections. Org-level defaults.
model Olettamus {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  avain     String       @map("avain")
  nimi      String       @map("nimi")
  arvo      Decimal      @map("arvo")
  yksikko   String?      @map("yksikko")
  kuvaus    String?      @map("kuvaus") // SV: beskrivning / EN: description
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([orgId, avain])
  @@map("olettamus")
}

// Ennuste (SV: Prognos / EN: Projection)
// A named scenario generating multi-year projections from a base budget + assumptions.
model Ennuste {
  id                       String       @id @default(uuid())
  orgId                    String
  org                      Organization @relation(fields: [orgId], references: [id])
  talousarvioId            String
  talousarvio              Talousarvio  @relation(fields: [talousarvioId], references: [id])
  nimi                     String       @map("nimi") // SV: namn / EN: name
  aikajaksoVuosia          Int          @map("aikajakso_vuosia") // SV: periodÃƒâ€¦r / EN: horizonYears
  olettamusYlikirjoitukset Json?        @map("olettamus_ylikirjoitukset")
  ajuriPolut               Json?        @map("ajuri_polut") // SV: drivbanor / EN: driver paths (per-year or % inputs)
  userInvestments          Json?        @map("user_investments")
  vuosiYlikirjoitukset     Json?        @map("vuosi_ylikirjoitukset") // Year-specific overrides for water price, category growth, investments and line-level adjustments
  baselineDepreciation     Json?        @map("baseline_depreciation")
  scenarioDepreciationRules Json?       @map("scenario_depreciation_rules")
  computedAt               DateTime?    @map("computed_at")
  computedFromUpdatedAt    DateTime?    @map("computed_from_updated_at")
  onOletus                 Boolean      @default(false) @map("on_oletus")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  vuodet EnnusteVuosi[]
  reports EnnusteReport[]
  selectedByVesinvestPlans VesinvestPlan[] @relation("VesinvestSelectedScenario")
  vesinvestTariffPlans VesinvestTariffPlan[]

  @@unique([orgId, nimi])
  @@index([orgId])
  @@map("ennuste")
}

model VesinvestPlanSeries {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  plans VesinvestPlan[]

  @@index([orgId, updatedAt])
  @@map("vesinvest_plan_series")
}

model VesinvestGroupDefinition {
  id                           String                @id @default(uuid())
  key                          String                @unique @map("key")
  label                        String                @map("label")
  defaultAccountKey            String                @map("default_account_key")
  defaultDepreciationClassKey  String?               @map("default_depreciation_class_key")
  reportGroupKey               String                @map("report_group_key")
  serviceSplit                 VesinvestServiceSplit @default(mixed) @map("service_split")
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")

  @@map("vesinvest_group_definition")
}

model VesinvestGroupOverride {
  id                          String                @id @default(uuid())
  orgId                       String
  org                         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  key                         String                @map("key")
  label                       String                @map("label")
  defaultAccountKey           String                @map("default_account_key")
  defaultDepreciationClassKey String?               @map("default_depreciation_class_key")
  reportGroupKey              String                @map("report_group_key")
  serviceSplit                VesinvestServiceSplit @default(mixed) @map("service_split")
  createdAt                   DateTime              @default(now()) @map("created_at")
  updatedAt                   DateTime              @updatedAt @map("updated_at")

  @@unique([orgId, key])
  @@index([orgId, updatedAt])
  @@map("vesinvest_group_override")
}

model VesinvestPlan {
  id                                       String                           @id @default(uuid())
  orgId                                    String
  org                                      Organization                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  seriesId                                 String                           @map("series_id")
  series                                   VesinvestPlanSeries              @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  name                                     String                           @map("name")
  utilityName                              String                           @map("utility_name")
  businessId                               String?                          @map("business_id")
  identitySource                           VesinvestIdentitySource          @default(manual) @map("identity_source")
  veetiId                                  Int?                             @map("veeti_id")
  horizonYears                             Int                              @default(20) @map("horizon_years")
  versionNumber                            Int                              @default(1) @map("version_number")
  status                                   VesinvestPlanStatus              @default(draft) @map("status")
  baselineStatus                           VesinvestBaselineStatus          @default(draft) @map("baseline_status")
  feeRecommendationStatus                  VesinvestFeeRecommendationStatus @default(blocked) @map("fee_recommendation_status")
  feeRecommendation                        Json?                            @map("fee_recommendation")
  baselineSourceState                      Json?                            @map("baseline_source_state")
  baselineFingerprint                      String?                          @map("baseline_fingerprint")
  scenarioFingerprint                      String?                          @map("scenario_fingerprint")
  selectedScenarioId                       String?                          @map("selected_scenario_id")
  selectedScenario                         Ennuste?                         @relation("VesinvestSelectedScenario", fields: [selectedScenarioId], references: [id], onDelete: SetNull)
  sourcePlanId                             String?                          @map("source_plan_id")
  sourcePlan                               VesinvestPlan?                   @relation("VesinvestPlanRevision", fields: [sourcePlanId], references: [id], onDelete: SetNull)
  revisions                                VesinvestPlan[]                  @relation("VesinvestPlanRevision")
  lastReviewedAt                           DateTime?                        @map("last_reviewed_at")
  reviewDueAt                              DateTime?                        @map("review_due_at")
  baselineChangedSinceAcceptedRevision     Boolean                          @default(false) @map("baseline_changed_since_accepted_revision")
  investmentPlanChangedSinceFeeRecommendation Boolean                       @default(true) @map("investment_plan_changed_since_fee_recommendation")
  createdAt                                DateTime                         @default(now()) @map("created_at")
  updatedAt                                DateTime                         @updatedAt @map("updated_at")

  projects VesinvestProject[]
  reports  EnnusteReport[]                  @relation("VesinvestPlanReports")
  tariffPlans VesinvestTariffPlan[]

  @@index([orgId, updatedAt])
  @@index([orgId, status])
  @@index([orgId, reviewDueAt])
  @@index([seriesId, status])
  @@unique([seriesId, versionNumber])
  @@map("vesinvest_plan")
}

model VesinvestTariffPlan {
  id                 String                    @id @default(uuid())
  orgId              String                    @map("org_id")
  org                Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vesinvestPlanId    String                    @map("vesinvest_plan_id")
  vesinvestPlan      VesinvestPlan             @relation(fields: [vesinvestPlanId], references: [id], onDelete: Cascade)
  scenarioId         String                    @map("scenario_id")
  scenario           Ennuste                   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  status             VesinvestTariffPlanStatus @default(draft)
  baselineInput      Json                      @map("baseline_input")
  allocationPolicy   Json                      @map("allocation_policy")
  recommendation     Json                      @map("recommendation")
  readinessChecklist Json                      @map("readiness_checklist")
  acceptedAt         DateTime?                 @map("accepted_at")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  @@index([orgId, updatedAt])
  @@index([vesinvestPlanId, status])
  @@index([scenarioId, status])
  @@map("vesinvest_tariff_plan")
}

model VesinvestProject {
  id                   String                  @id @default(uuid())
  planId               String                  @map("plan_id")
  plan                 VesinvestPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  projectCode          String                  @map("project_code")
  projectName          String                  @map("project_name")
  investmentType       VesinvestInvestmentType @map("investment_type")
  groupKey             String                  @map("group_key")
  depreciationClassKey String?                 @map("depreciation_class_key")
  accountKey           String?                 @map("account_key")
  reportGroupKey       String?                 @map("report_group_key")
  subtype              String?                 @map("subtype")
  notes                String?                 @map("notes")
  waterAmount          Decimal?                @map("water_amount")
  wastewaterAmount     Decimal?                @map("wastewater_amount")
  totalAmount          Decimal?                @map("total_amount")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  allocations VesinvestProjectAllocation[]

  @@unique([planId, projectCode])
  @@index([planId, investmentType])
  @@map("vesinvest_project")
}

model VesinvestProjectAllocation {
  id              String            @id @default(uuid())
  projectId       String            @map("project_id")
  project         VesinvestProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  year            Int               @map("year")
  waterAmount     Decimal?          @map("water_amount")
  wastewaterAmount Decimal?         @map("wastewater_amount")
  totalAmount     Decimal           @map("total_amount")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([projectId, year])
  @@index([year])
  @@map("vesinvest_project_allocation")
}

model EnnusteReport {
  id                        String       @id @default(uuid())
  orgId                     String
  org                       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ennusteId                 String       @map("ennuste_id")
  ennuste                   Ennuste      @relation(fields: [ennusteId], references: [id], onDelete: Cascade)
  vesinvestPlanId           String?      @map("vesinvest_plan_id")
  vesinvestPlan             VesinvestPlan? @relation("VesinvestPlanReports", fields: [vesinvestPlanId], references: [id], onDelete: SetNull)
  title                     String       @map("title")
  createdByUserId           String       @map("created_by_user_id")
  createdBy                 User         @relation("EnnusteReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt                 DateTime     @default(now()) @map("created_at")
  snapshotJson              Json         @map("snapshot_json")
  snapshotVersion           Int          @default(1) @map("snapshot_version")
  baselineYear              Int          @map("baseline_year")
  requiredPriceToday        Decimal      @map("required_price_today")
  requiredAnnualIncreasePct Decimal      @map("required_annual_increase_pct")
  totalInvestments          Decimal      @map("total_investments")

  @@index([orgId, createdAt])
  @@index([ennusteId])
  @@index([vesinvestPlanId])
  @@map("ennuste_report")
}


// Computed output row for each year in a projection.
model EnnusteVuosi {
  id                   String   @id @default(uuid())
  ennusteId            String
  ennuste              Ennuste  @relation(fields: [ennusteId], references: [id], onDelete: Cascade)
  vuosi                Int      @map("vuosi")
  tulotYhteensa        Decimal  @map("tulot_yhteensa")
  kulutYhteensa        Decimal  @map("kulut_yhteensa") // SV: kostnaderTotalt / EN: totalExpenses
  investoinnitYhteensa Decimal  @map("investoinnit_yhteensa") // SV: investeringarTotalt / EN: totalInvestments
  poistoPerusta        Decimal? @map("poisto_perusta") // S-03: baseline depreciation
  poistoInvestoinneista Decimal? @map("poisto_investoinneista") // S-03: investment-driven depreciation
  tulos                Decimal  @map("tulos") // SV: resultat / EN: netResult
  kumulatiivinenTulos  Decimal  @map("kumulatiivinen_tulos") // SV: kumulativtResultat / EN: cumulativeResult
  vesihinta            Decimal? @map("vesihinta") // SV: vattenpris / EN: waterPrice
  myytyVesimaara       Decimal? @map("myyty_vesimaara")
  erittelyt            Json?    @map("erittelyt") // SV: specifikationer / EN: breakdown

  @@unique([ennusteId, vuosi])
  @@map("ennuste_vuosi")
}
