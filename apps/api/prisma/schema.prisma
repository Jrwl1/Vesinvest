generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// LEGACY enums (asset management system)
// Kept for backward compatibility; feature-flagged at API level
// ============================================

enum AssetStatus {
  active
  inactive
  retired
}

enum Criticality {
  low
  medium
  high
}

enum MaintenanceKind {
  MAINTENANCE
  REPLACEMENT
}

enum RenewalStrategy {
  linear
  clustered
  risk_based
}

enum ImportStatus {
  pending
  mapped
  imported
  failed
}

enum TargetEntity {
  asset
  assetType
  site
  maintenanceItem
}

enum FieldCriticality {
  law_critical
  model_critical
  optional
}

enum ImportAction {
  created
  updated
  skipped
}

// ============================================
// NEW enums (VA budget/projection system)
// ============================================

// Talousarvion tila (SV: Budgetstatus / EN: Budget status)
enum TalousarvioTila {
  luonnos // SV: utkast / EN: draft
  vahvistettu // SV: fastställd / EN: confirmed
}

// Budjettirivien tyyppi (SV: Budgetradtyp / EN: Budget line type)
enum RiviTyyppi {
  kulu // SV: kostnad / EN: expense
  tulo // SV: intäkt / EN: revenue
  investointi // SV: investering / EN: investment
}

// Palvelutyyppi (SV: Tjänstetyp / EN: Service type)
enum Palvelutyyppi {
  vesi // SV: vatten / EN: water
  jatevesi // SV: avloppsvatten / EN: wastewater
  muu // SV: övrigt / EN: other
}

// Välisummatyyppi (SV: Mellansummatyp / EN: Subtotal line type)
// Semantic classification for P&L subtotal rows from KVA workbook.
enum ValisummaTyyppi {
  tulo // SV: intäkt / EN: income
  kulu // SV: kostnad / EN: cost
  poisto // SV: avskrivning / EN: depreciation
  rahoitus_tulo // SV: finansiell intäkt / EN: financial income
  rahoitus_kulu // SV: finansiell kostnad / EN: financial cost
  investointi // SV: investering / EN: investment
  tulos // SV: resultat / EN: result (computed, not projection input)
}

// ============================================
// Core models (kept as-is)
// ============================================

model Organization {
  id                       String           @id @default(uuid())
  slug                     String           @unique
  name                     String
  renewalStrategy          RenewalStrategy? // LEGACY
  annualRenewalCapacityEur Decimal? // LEGACY
  created_at               DateTime         @default(now())

  // LEGACY relations
  users             UserRole[]
  sites             Site[]
  assetTypes        AssetType[]
  assets            Asset[]
  maintenanceItems  MaintenanceItem[]
  planningScenarios PlanningScenario[]
  excelImports      ExcelImport[]
  importMappings    ImportMapping[]

  // NEW: VA budget relations
  talousarviot Talousarvio[]
  olettamukset Olettamus[]
  ennusteet    Ennuste[]
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  created_at DateTime   @default(now())
  roles      UserRole[]
}

model Role {
  id         String     @id @default(uuid())
  name       String     @unique
  created_at DateTime   @default(now())
  users      UserRole[]
}

model UserRole {
  id         String       @id @default(uuid())
  created_at DateTime     @default(now())
  user       User         @relation(fields: [user_id], references: [id])
  user_id    String
  role       Role         @relation(fields: [role_id], references: [id])
  role_id    String
  org        Organization @relation(fields: [org_id], references: [id])
  org_id     String

  @@unique([user_id, role_id, org_id])
}

// ============================================
// LEGACY models (asset management system)
// Kept for backward compatibility; feature-flagged at API level via LEGACY_ASSET_MODE
// ============================================

model Site {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  name      String
  address   String?
  createdAt DateTime     @default(now())
  assets    Asset[]
}

model AssetType {
  id               String       @id @default(uuid())
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id])
  code             String
  name             String
  defaultLifeYears Int?
  createdAt        DateTime     @default(now())
  assets           Asset[]

  @@unique([orgId, code])
}

model Asset {
  id                 String            @id @default(uuid())
  orgId              String
  org                Organization      @relation(fields: [orgId], references: [id])
  siteId             String
  site               Site              @relation(fields: [siteId], references: [id])
  assetTypeId        String
  assetType          AssetType         @relation(fields: [assetTypeId], references: [id])
  externalRef        String
  derivedIdentity    Boolean           @default(false)
  name               String
  installedOn        DateTime?
  lifeYears          Int?
  replacementCostEur Decimal?
  criticality        Criticality?
  status             AssetStatus
  assumedFields      Json?
  ownerRole          String?
  notes              String?
  sourceImportId     String?
  sourceSheetName    String?
  sourceRowNumber    Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  maintenanceItems   MaintenanceItem[]

  @@unique([orgId, externalRef])
  @@index([orgId, siteId])
  @@index([orgId, assetTypeId])
  @@index([orgId, status])
  @@index([sourceImportId])
}

model MaintenanceItem {
  id            String          @id @default(uuid())
  orgId         String
  assetId       String
  kind          MaintenanceKind
  intervalYears Int
  costEur       Decimal
  startsAtYear  Int?
  endsAtYear    Int?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  asset Asset        @relation(fields: [assetId], references: [id])
  org   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, assetId])
  @@index([orgId, kind])
}

// LEGACY: Planning Scenarios
model PlanningScenario {
  id                   String       @id @default(uuid())
  orgId                String
  org                  Organization @relation(fields: [orgId], references: [id])
  name                 String
  planningHorizonYears Int          @default(20)
  inflationRate        Decimal      @default(0.02)
  discountRate         Decimal      @default(0.03)
  currentTariffEur     Decimal?
  revenueBaselineEur   Decimal?
  isDefault            Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

// LEGACY: Excel Import
model ExcelImport {
  id              String           @id @default(uuid())
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id])
  filename        String
  status          ImportStatus     @default(pending)
  uploadedAt      DateTime         @default(now())
  sheets          ExcelSheet[]
  importedRecords ImportedRecord[]

  @@index([orgId])
  @@index([orgId, status])
}

model ExcelSheet {
  id                String      @id @default(uuid())
  importId          String
  import            ExcelImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  sheetName         String
  headers           String[]
  rowCount          Int
  sampleRows        Json?
  columnsProfile    Json?
  dataRowCount      Int?
  headerRowsSkipped Int?
  kind              String?
  kindReason        String?

  @@index([importId])
}

model ImportedRecord {
  id         String       @id @default(uuid())
  importId   String
  import     ExcelImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  entityType TargetEntity
  entityId   String
  sheetName  String
  rowNumber  Int
  rowHash    String
  action     ImportAction @default(created)
  matchKey   String?
  matchValue String?
  createdAt  DateTime     @default(now())

  @@unique([importId, sheetName, rowNumber])
  @@unique([importId, rowHash, entityType])
  @@index([importId])
  @@index([entityId])
  @@index([rowHash])
}

model ImportMapping {
  id           String          @id @default(uuid())
  orgId        String
  org          Organization    @relation(fields: [orgId], references: [id])
  name         String
  targetEntity TargetEntity
  version      Int             @default(1)
  isTemplate   Boolean         @default(false)
  columns      MappingColumn[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([orgId, name, version])
  @@index([orgId])
}

model MappingColumn {
  id             String           @id @default(uuid())
  mappingId      String
  mapping        ImportMapping    @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  sourceColumn   String
  targetField    String
  transformation Json?
  required       Boolean          @default(false)
  criticality    FieldCriticality @default(optional)

  @@index([mappingId])
}

// ============================================
// NEW: VA Budget / Projection Models
// Finnish terminology primary; SV/EN in comments
// ============================================

// Talousarvio (SV: Budget / EN: Budget)
// Named budget profile. Multiple profiles allowed per org per year (different nimi).
model Talousarvio {
  id                    String           @id @default(uuid())
  orgId                 String
  org                   Organization     @relation(fields: [orgId], references: [id])
  vuosi                 Int              @map("vuosi") // SV: år / EN: year
  nimi                  String           @map("nimi") // SV: namn / EN: name — required profile name
  tila                  TalousarvioTila  @default(luonnos) // SV: status / EN: status
  perusmaksuYhteensa    Decimal?         @map("perusmaksu_yhteensa") // SV: grundavgift totalt / EN: annual base-fee total (EUR)
  importBatchId         String?          @map("import_batch_id") // KVA import: same id for 3 budgets in one run
  importSourceFileName  String?          @map("import_source_file_name") // Källa: Excel filename
  importedAt            DateTime?       @map("imported_at") // Källa: import timestamp
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  rivit      TalousarvioRivi[]
  tuloajurit Tuloajuri[]
  valisummat TalousarvioValisumma[]
  ennusteet  Ennuste[]

  @@unique([orgId, vuosi, nimi])
  @@index([orgId, importBatchId])
  @@map("talousarvio")
}

// TalousarvioRivi (SV: Budgetrad / EN: BudgetLine)
// Individual cost/revenue/investment line within a budget.
model TalousarvioRivi {
  id            String      @id @default(uuid())
  talousarvioId String
  talousarvio   Talousarvio @relation(fields: [talousarvioId], references: [id], onDelete: Cascade)
  tiliryhma     String      @map("tiliryhma") // SV: kontogrupp / EN: accountGroup — e.g. "4000"
  nimi          String      @map("nimi") // SV: namn / EN: name — e.g. "Energiakustannukset"
  tyyppi        RiviTyyppi // SV: typ / EN: type
  summa         Decimal     @map("summa") // SV: belopp / EN: amount — EUR, always positive
  muistiinpanot String?     @map("muistiinpanot") // SV: anteckningar / EN: notes
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([talousarvioId])
  @@map("talousarvio_rivi")
}

// TalousarvioValisumma (SV: Budgetmellansumma / EN: BudgetSubtotal)
// Subtotal-level P&L lines extracted from KVA workbook.
// Used for 20-year projections via "computeFromSubtotals" path.
model TalousarvioValisumma {
  id            String          @id @default(uuid())
  talousarvioId String
  talousarvio   Talousarvio     @relation(fields: [talousarvioId], references: [id], onDelete: Cascade)
  palvelutyyppi Palvelutyyppi // SV: tjänstetyp / EN: serviceType — vesi/jatevesi/muu
  categoryKey   String          @map("category_key") // SV: kategorinyckel / EN: categoryKey — stable key e.g. "sales_revenue"
  tyyppi        ValisummaTyyppi // SV: typ / EN: type — semantic classification
  label         String?         @map("label") // SV: etikett / EN: label — original Excel label
  summa         Decimal         @map("summa") // SV: belopp / EN: amount — EUR
  lahde         String?         @map("lahde") // SV: källa / EN: source — e.g. "KVA"
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([talousarvioId, palvelutyyppi, categoryKey])
  @@index([talousarvioId])
  @@map("talousarvio_valisumma")
}

// Tuloajuri (SV: Intäktsdrivare / EN: RevenueDriver)
// Unit price + volume data that budgets typically lack. Compliance-critical.
model Tuloajuri {
  id            String        @id @default(uuid())
  talousarvioId String
  talousarvio   Talousarvio   @relation(fields: [talousarvioId], references: [id], onDelete: Cascade)
  palvelutyyppi Palvelutyyppi // SV: tjänstetyp / EN: serviceType
  yksikkohinta  Decimal       @map("yksikkohinta") // SV: enhetspris / EN: unitPrice — EUR/m³
  myytyMaara    Decimal       @map("myyty_maara") // SV: såld volym / EN: soldVolume — m³/year
  perusmaksu    Decimal?      @map("perusmaksu") // SV: grundavgift / EN: baseFee — EUR/connection
  liittymamaara Int?          @map("liittyma_maara") // SV: antal anslutningar / EN: connectionCount
  alvProsentti  Decimal?      @map("alv_prosentti") // SV: momsprocent / EN: vatPercent — default 24%
  muistiinpanot String?       @map("muistiinpanot") // SV: anteckningar / EN: notes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([talousarvioId])
  @@map("tuloajuri")
}

// Olettamus (SV: Antagande / EN: Assumption)
// Named key-value assumptions for projections. Org-level defaults.
model Olettamus {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  avain     String       @map("avain") // SV: nyckel / EN: key — e.g. "inflaatio"
  nimi      String       @map("nimi") // SV: namn / EN: name — human-readable label
  arvo      Decimal      @map("arvo") // SV: värde / EN: value — numeric, e.g. 0.025
  yksikko   String?      @map("yksikko") // SV: enhet / EN: unit — display unit, e.g. "%"
  kuvaus    String?      @map("kuvaus") // SV: beskrivning / EN: description
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([orgId, avain])
  @@map("olettamus")
}

// Ennuste (SV: Prognos / EN: Projection)
// A named scenario generating multi-year projections from a base budget + assumptions.
model Ennuste {
  id                       String       @id @default(uuid())
  orgId                    String
  org                      Organization @relation(fields: [orgId], references: [id])
  talousarvioId            String
  talousarvio              Talousarvio  @relation(fields: [talousarvioId], references: [id])
  nimi                     String       @map("nimi") // SV: namn / EN: name
  aikajaksoVuosia          Int          @map("aikajakso_vuosia") // SV: periodÅr / EN: horizonYears
  olettamusYlikirjoitukset Json?        @map("olettamus_ylikirjoitukset") // SV: antagandeöverskrivningar / EN: assumptionOverrides
  ajuriPolut               Json?        @map("ajuri_polut") // SV: drivbanor / EN: driver paths (per-year or % inputs)
  userInvestments          Json?        @map("user_investments") // Array of {year, amount} — user-added investments merged with baseline
  onOletus                 Boolean      @default(false) @map("on_oletus") // SV: ärStandard / EN: isDefault
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  vuodet EnnusteVuosi[]

  @@unique([orgId, nimi])
  @@index([orgId])
  @@map("ennuste")
}

// EnnusteVuosi (SV: Prognosår / EN: ProjectionYear)
// Computed output row for each year in a projection.
model EnnusteVuosi {
  id                   String   @id @default(uuid())
  ennusteId            String
  ennuste              Ennuste  @relation(fields: [ennusteId], references: [id], onDelete: Cascade)
  vuosi                Int      @map("vuosi") // SV: år / EN: year
  tulotYhteensa        Decimal  @map("tulot_yhteensa") // SV: intäkterTotalt / EN: totalRevenue
  kulutYhteensa        Decimal  @map("kulut_yhteensa") // SV: kostnaderTotalt / EN: totalExpenses
  investoinnitYhteensa Decimal  @map("investoinnit_yhteensa") // SV: investeringarTotalt / EN: totalInvestments
  poistoPerusta        Decimal? @map("poisto_perusta") // S-03: baseline depreciation
  poistoInvestoinneista Decimal? @map("poisto_investoinneista") // S-03: investment-driven depreciation
  tulos                Decimal  @map("tulos") // SV: resultat / EN: netResult
  kumulatiivinenTulos  Decimal  @map("kumulatiivinen_tulos") // SV: kumulativtResultat / EN: cumulativeResult
  vesihinta            Decimal? @map("vesihinta") // SV: vattenpris / EN: waterPrice
  myytyVesimaara       Decimal? @map("myyty_vesimaara") // SV: såldVolym / EN: soldVolume
  erittelyt            Json?    @map("erittelyt") // SV: specifikationer / EN: breakdown

  @@unique([ennusteId, vuosi])
  @@map("ennuste_vuosi")
}
