# API Base URL (required in production only)
# Production: MUST be set (e.g. your Railway API URL).
# Development: if unset, defaults to http://localhost:3000 (see apps/api PORT).
#   Set to a tunnel URL (e.g. trycloudflare) only when using a tunnel; for local testing leave unset or use http://localhost:3000.
# apps/web/.env.development sets VITE_API_BASE_URL=http://localhost:3000 for local API (restart dev server after changing).
# VITE_API_BASE_URL=

# Demo: "Use Demo" on the Sign In page is the ONLY way to start demo. No auto-login.
# Demo availability is determined by GET /demo/status (backend DEMO_MODE). Not from env.
# VITE_AUTO_DEMO_LOGIN is not used; default is OFF (we never auto-login).
# The browser never ships a demo secret. Demo gating is owned by the backend.
