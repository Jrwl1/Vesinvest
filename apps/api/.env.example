# Database connection (required)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT secret for signing tokens (required, use a strong random string)
JWT_SECRET="your-secure-jwt-secret-at-least-32-characters"

# Server port (Railway sets this automatically)
PORT=3000

# Environment (set to 'production' in production)
NODE_ENV=production

# CORS allowed origins (comma-separated)
# In production: only these origins are allowed
# In development: localhost:5173,localhost:3000 are also allowed automatically
# Never use '*' with credentials:true
# Example: CORS_ORIGINS=https://plan20-web.vercel.app,https://custom-domain.com
CORS_ORIGINS=https://plan20-web.vercel.app

# Dev-only: Enable dev-token bypass in non-development environments (NOT recommended for production)
# DEV_AUTH_BYPASS=true

# Demo mode: When DEMO_MODE=true, authentication is COMPLETELY BYPASSED.
# All requests use a deterministic demo organization (demo-org-00000000-0000-0000-0000-000000000001).
# The demo org is auto-created on startup with sample sites and asset types.
# Frontend detects this via GET /health/config and skips login UI entirely.
#
# WARNING: Never enable DEMO_MODE in production with real data!
# This is intended for demos, testing, and local development only.
#
# DEMO_MODE=true
#
# Legacy demo login (requires DEMO_KEY header, kept for backwards compatibility):
# DEMO_KEY=your-random-secret-key-here
