# API Base URL (required in production only)
# Production: MUST be set (e.g. your Railway API URL).
# Development: omit or leave empty to use same-origin /api (Vite proxy to localhost:3000).
#   With proxy default, a single Cloudflare tunnel for the web app is enough; no API tunnel or env needed.
# Override in dev: set to e.g. http://localhost:3000 or an API tunnel URL if you prefer.
# VITE_API_BASE_URL=

# Demo: "Use Demo" on the Sign In page is the ONLY way to start demo. No auto-login.
# Demo availability is determined by GET /demo/status (backend DEMO_MODE). Not from env.
# VITE_AUTO_DEMO_LOGIN is not used; default is OFF (we never auto-login).

# Demo key: shared secret for demo login (MUST match API DEMO_KEY when set)
# VITE_DEMO_KEY=your-random-secret-key-here
