# Database connection (required)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT secret for signing tokens (required, use a strong random string)
JWT_SECRET="your-secure-jwt-secret-at-least-32-characters"

# Server port (Railway sets this automatically)
PORT=3000

# Environment (set to 'production' in production)
NODE_ENV=production

# App mode controls tenant behavior:
# - production: normal hosted customer mode
# - trial: normal non-demo evaluation mode (default when APP_MODE is unset outside production)
# - internal_demo: enables demo login plus demo seed/reset endpoints
# APP_MODE=trial

# CORS allowed origins (comma-separated)
# Production: only these origins are allowed.
# Development: localhost:5173, 5174, 127.0.0.1:5173/5174, localhost:3000 are always allowed.
#   *.trycloudflare.com is also accepted in dev for Cloudflare quick tunnels.
#   In internal demo mode, ALL origins are accepted.
# Example: CORS_ORIGINS=https://plan20-web.vercel.app
CORS_ORIGINS=https://plan20-web.vercel.app

# Trusted proxy handling for req.ip. Keep false locally; set to the trusted proxy hop
# count, CIDR label, or true only when the API sits behind a trusted reverse proxy.
# TRUST_PROXY=1

# Auth rate-limit contract:
# - Local/non-production default: in-process memory limiter
# - Production requirement: AUTH_RATE_LIMIT_MODE=edge
# When edge mode is enabled, the reverse proxy / edge MUST:
# 1. rate-limit /auth/login, /auth/demo-login, and /auth/invitations/accept
# 2. strip any client-supplied x-auth-rate-limit-verified header
# 3. inject x-auth-rate-limit-verified with AUTH_EDGE_RATE_LIMIT_SECRET before forwarding
# AUTH_RATE_LIMIT_MODE=edge
# AUTH_EDGE_RATE_LIMIT_SECRET=replace-with-long-random-secret

# Dev-only: Enable dev-token bypass in non-development environments (NOT recommended for production)
# DEV_AUTH_BYPASS=true

# Demo mode: GET /demo/status and POST /auth/demo-login.
# - Preferred: set APP_MODE=internal_demo for local or hosted demo instances.
# - Default when APP_MODE is unset: non-production runs in trial mode, production runs in production mode.
# - Legacy fallback: DEMO_MODE=true still enables internal demo mode when APP_MODE is unset.
# DEMO_MODE=true
