# Database connection (required)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT secret for signing tokens (required, use a strong random string)
JWT_SECRET="your-secure-jwt-secret-at-least-32-characters"

# Server port (Railway sets this automatically)
PORT=3000

# Environment (set to 'production' in production)
NODE_ENV=production

# CORS allowed origins (comma-separated)
# Production: only these origins are allowed.
# Development: localhost:5173, 5174, 127.0.0.1:5173/5174, localhost:3000 are also allowed. Add other ports here.
# Example: CORS_ORIGINS=https://plan20-web.vercel.app
CORS_ORIGINS=https://plan20-web.vercel.app

# Dev-only: Enable dev-token bypass in non-development environments (NOT recommended for production)
# DEV_AUTH_BYPASS=true

# Demo mode: GET /demo/status and POST /auth/demo-login.
# - Local dev: ON by default (NODE_ENV !== production). Set DEMO_MODE=false to turn off.
# - Production: OFF unless DEMO_MODE=true (use only for dedicated demo instances).
# DEMO_MODE=false
#
# Optional: when set, POST /auth/demo-login requires x-demo-key header to match (e.g. for public demos).
# DEMO_KEY=your-random-secret-key-here
