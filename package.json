{
  "name": "saas-monorepo",
  "private": true,
  "license": "UNLICENSED",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm dev:clean && node scripts/dev-up.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:fresh": "pnpm dev",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "build": "pnpm --filter \"./packages/*\" --filter \"!./packages/config\" -r build && pnpm --filter \"./apps/*\" -r build",
    "build:api": "pnpm --filter ./apps/api build",
    "audit:prod": "pnpm audit --prod --json",
    "check:text-integrity": "node scripts/check-text-integrity.mjs",
    "lint": "pnpm check:text-integrity && pnpm --filter \"!./packages/config\" -r lint",
    "next:steps": "node scripts/openclaw/update-next-steps.mjs",
    "release-check": "pnpm audit:prod && pnpm --filter ./apps/api test:upload-security && pnpm check:prisma-lock && pnpm lint && pnpm typecheck && pnpm test && pnpm --filter ./apps/api build && pnpm --filter ./apps/web build && pnpm smoke:v2",
    "security-perf:reaudit": "pnpm --filter ./apps/web test -- src/App.test.tsx src/components/LoginForm.test.tsx src/v2/AppShellV2.test.tsx src/v2/OverviewPageV2.test.tsx src/v2/EnnustePageV2.test.tsx src/v2/ReportsPageV2.test.tsx src/i18n/locales/localeIntegrity.test.ts && pnpm --filter ./apps/api test -- src/auth/auth.controller.spec.ts src/v2/v2.service.spec.ts test/app.module.spec.ts && pnpm --filter ./apps/web typecheck && pnpm --filter ./apps/api typecheck",
    "check:prisma-lock": "node scripts/check-prisma-lock.mjs",
    "ops:funnel:check": "node scripts/ops/funnel-report.mjs",
    "ops:veeti:parity": "node scripts/ops/veeti-1535-parity.mjs",
    "smoke:v2": "pnpm --filter ./apps/web test -- src/v2/overviewWorkflow.test.ts src/v2/AppShellV2.test.tsx",
    "typecheck": "pnpm --filter \"!./packages/config\" -r typecheck",
    "test": "pnpm --filter \"!./packages/config\" -r test",
    "deploy:prod": "node ./scripts/deploy-prod.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.0.0",
    "prettier": "^2.0.0",
    "typescript": "^5.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "1.1.13",
      "file-type": "21.3.3",
      "minimatch": "3.1.4",
      "multer": "2.1.1",
      "path-to-regexp": "0.1.13"
    }
  }
}
