generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetStatus {
  active
  inactive
  retired
}

enum Criticality {
  low
  medium
  high
}

enum MaintenanceKind {
  MAINTENANCE
  REPLACEMENT
}

enum RenewalStrategy {
  linear
  clustered
  risk_based
}

enum ImportStatus {
  pending
  mapped
  imported
  failed
}

enum TargetEntity {
  asset
  assetType
  site
  maintenanceItem
}

enum FieldCriticality {
  law_critical
  model_critical
  optional
}

enum ImportAction {
  created
  updated
  skipped
}

model Organization {
  id                       String             @id @default(uuid())
  slug                     String             @unique
  name                     String
  renewalStrategy          RenewalStrategy?
  annualRenewalCapacityEur Decimal?
  created_at               DateTime           @default(now())
  users                    UserRole[]
  sites                    Site[]
  assetTypes               AssetType[]
  assets                   Asset[]
  maintenanceItems         MaintenanceItem[]
  planningScenarios        PlanningScenario[]
  excelImports             ExcelImport[]
  importMappings           ImportMapping[]
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  created_at DateTime   @default(now())
  roles      UserRole[]
}

model Role {
  id         String     @id @default(uuid())
  name       String     @unique
  created_at DateTime   @default(now())
  users      UserRole[]
}

model UserRole {
  id         String       @id @default(uuid())
  created_at DateTime     @default(now())
  user       User         @relation(fields: [user_id], references: [id])
  user_id    String
  role       Role         @relation(fields: [role_id], references: [id])
  role_id    String
  org        Organization @relation(fields: [org_id], references: [id])
  org_id     String

  @@unique([user_id, role_id, org_id])
}

model Site {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  name      String
  address   String?
  createdAt DateTime     @default(now())
  assets    Asset[]
}

model AssetType {
  id               String       @id @default(uuid())
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id])
  code             String
  name             String
  defaultLifeYears Int?
  createdAt        DateTime     @default(now())
  assets           Asset[]

  @@unique([orgId, code])
}

model Asset {
  id                 String            @id @default(uuid())
  orgId              String
  org                Organization      @relation(fields: [orgId], references: [id])
  siteId             String
  site               Site              @relation(fields: [siteId], references: [id])
  assetTypeId        String
  assetType          AssetType         @relation(fields: [assetTypeId], references: [id])
  // === Asset Identity Contract ===
  // externalRef is the BUSINESS IDENTITY - see docs/IdentityContract/ASSET_IDENTITY_CONTRACT.md
  // - Required for all law-critical assets
  // - Immutable after creation (enforced at API level)
  // - All matching, updates, and projections key off this field
  externalRef        String
  // derivedIdentity = true means this externalRef was auto-generated (fallback)
  // and can be replaced later with a real utility-internal ID
  derivedIdentity    Boolean           @default(false)
  // === End Identity Contract ===
  name               String
  installedOn        DateTime?
  // ageYears is NOT stored; computed at API boundary as currentYear - year(installedOn)
  lifeYears          Int?
  replacementCostEur Decimal?
  criticality        Criticality?  // optional; projections exclude assets missing lifetime/cost
  status             AssetStatus
  // === Assumed Fields / Provenance (Auto-Extract) ===
  // JSON: per-field source (excel | default | derived | manual | missing), value?, derivedFrom?
  assumedFields      Json?
  ownerRole          String?
  notes              String?
  // Provenance fields (Stage 4)
  sourceImportId     String?
  sourceSheetName    String?
  sourceRowNumber    Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  maintenanceItems   MaintenanceItem[]

  // externalRef is unique within an organization - this is the business identity
  @@unique([orgId, externalRef])
  @@index([orgId, siteId])
  @@index([orgId, assetTypeId])
  @@index([orgId, status])
  @@index([sourceImportId])
}

model MaintenanceItem {
  id            String          @id @default(uuid())
  orgId         String
  assetId       String
  kind          MaintenanceKind
  intervalYears Int
  costEur       Decimal
  startsAtYear  Int?
  endsAtYear    Int?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  asset Asset        @relation(fields: [assetId], references: [id])
  org   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, assetId])
  @@index([orgId, kind])
}

// ============================================
// Planning Scenarios (Stage 1)
// ============================================

model PlanningScenario {
  id                   String       @id @default(uuid())
  orgId                String
  org                  Organization @relation(fields: [orgId], references: [id])
  name                 String
  planningHorizonYears Int          @default(20)
  inflationRate        Decimal      @default(0.02)
  discountRate         Decimal      @default(0.03)
  currentTariffEur     Decimal?
  revenueBaselineEur   Decimal?
  isDefault            Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

// ============================================
// Excel Import (Stage 2)
// ============================================

model ExcelImport {
  id              String           @id @default(uuid())
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id])
  filename        String
  status          ImportStatus     @default(pending)
  uploadedAt      DateTime         @default(now())
  sheets          ExcelSheet[]
  importedRecords ImportedRecord[]

  @@index([orgId])
  @@index([orgId, status])
}

model ExcelSheet {
  id                String      @id @default(uuid())
  importId          String
  import            ExcelImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  sheetName         String
  headers           String[]
  rowCount          Int
  sampleRows        Json?
  // Column profiling for better mapping and transformations
  columnsProfile    Json? // Array of ColumnProfile objects
  // Sheet analysis (migration: add_sheet_analysis_fields). # of data rows, header rows skipped, classification.
  dataRowCount      Int?    // Data rows detected (not counting header/descriptor rows)
  headerRowsSkipped Int?    // Header/descriptor rows skipped
  kind              String? // ASSET_CANDIDATE | REFERENCE | EMPTY | UNKNOWN
  kindReason        String?

  @@index([importId])
}

// ============================================
// Imported Records (Idempotency Tracking)
// ============================================

model ImportedRecord {
  id         String       @id @default(uuid())
  importId   String
  import     ExcelImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  entityType TargetEntity
  entityId   String // ID of the created/updated entity (e.g., Asset.id)
  sheetName  String
  rowNumber  Int
  rowHash    String // Stable hash of mapped row values
  action     ImportAction @default(created)
  matchKey   String? // The key used to match existing record
  matchValue String? // The value of the match key
  createdAt  DateTime     @default(now())

  @@unique([importId, sheetName, rowNumber])
  @@unique([importId, rowHash, entityType])
  @@index([importId])
  @@index([entityId])
  @@index([rowHash])
}

// ============================================
// Import Mapping (Stage 3)
// ============================================

model ImportMapping {
  id           String          @id @default(uuid())
  orgId        String
  org          Organization    @relation(fields: [orgId], references: [id])
  name         String
  targetEntity TargetEntity
  version      Int             @default(1)
  isTemplate   Boolean         @default(false)
  columns      MappingColumn[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([orgId, name, version])
  @@index([orgId])
}

model MappingColumn {
  id             String           @id @default(uuid())
  mappingId      String
  mapping        ImportMapping    @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  sourceColumn   String
  targetField    String
  transformation Json?
  required       Boolean          @default(false)
  criticality    FieldCriticality @default(optional)

  @@index([mappingId])
}
