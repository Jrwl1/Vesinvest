{
  "name": "saas-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm dev:clean && node scripts/dev-up.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:fresh": "pnpm dev",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "build": "pnpm --filter \"./packages/*\" --filter \"!./packages/config\" -r build && pnpm --filter \"./apps/*\" -r build",
    "build:api": "pnpm --filter ./apps/api build",
    "check:text-integrity": "node scripts/check-text-integrity.mjs",
    "lint": "pnpm check:text-integrity && pnpm --filter \"!./packages/config\" -r lint",
    "next:steps": "node scripts/openclaw/update-next-steps.mjs",
    "release-check": "pnpm check:prisma-lock && pnpm lint && pnpm typecheck && pnpm test && pnpm --filter ./apps/api build && pnpm --filter ./apps/web build && pnpm smoke:v2",
    "check:prisma-lock": "node scripts/check-prisma-lock.mjs",
    "ops:funnel:check": "node scripts/ops/funnel-report.mjs",
    "smoke:v2": "pnpm --filter ./apps/web test -- src/v2/overviewWorkflow.test.ts src/v2/AppShellV2.test.tsx",
    "typecheck": "pnpm --filter \"!./packages/config\" -r typecheck",
    "test": "pnpm --filter \"!./packages/config\" -r test",
    "deploy:prod": "bash ./scripts/deploy-prod.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.0.0",
    "prettier": "^2.0.0",
    "typescript": "^5.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}
